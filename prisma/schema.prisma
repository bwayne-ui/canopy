generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// CORE DOMAIN MODELS
// ──────────────────────────────────────────────

model Client {
  id                String   @id @default(cuid())
  name              String
  shortName         String?
  primaryStrategy   String
  hqCity            String
  hqCountry         String
  region            String
  relationshipStart DateTime
  status            String   @default("Active")
  totalEntities     Int      @default(0)
  totalNavMm        Decimal  @default(0)
  totalCommitmentMm Decimal  @default(0)
  revenueL12m       Decimal  @default(0)
  marginPct         Decimal  @default(0)
  teamLead          String
  podId             String?
  serviceLine       String
  yearFounded       Int?
  employeeCount     Int?
  website           String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  entities          Entity[]
}

model Entity {
  id                   String   @id @default(cuid())
  entityId             String   @unique
  name                 String
  entityType           String
  structureType        String
  domicile             String
  strategy             String
  vintage              Int?
  openEnded            Boolean  @default(false)
  lifecycleStatus      String
  clientId             String
  client               Client   @relation(fields: [clientId], references: [id])
  commitmentMm         Decimal?
  calledCapitalMm      Decimal?
  distributedCapitalMm Decimal?
  navMm                Decimal?
  unfundedMm           Decimal?
  prefRatePct          Decimal?
  carryPct             Decimal?
  mgmtFeePct           Decimal?
  waterfallType        String?
  grossIrrPct          Decimal?
  netIrrPct            Decimal?
  moic                 Decimal?
  tvpi                 Decimal?
  dpi                  Decimal?
  revenueL12m          Decimal?
  costL12m             Decimal?
  marginPct            Decimal?
  accountingSystem     String?
  administrator        String?
  auditor              String?
  legalCounsel         String?
  reportingFrequency   String?
  navFrequency         String?
  currency             String   @default("USD")
  inceptionDate        DateTime?
  hqCity               String?
  region               String?
  dataQualityScore     Decimal?
  confidenceScore      Decimal?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Investor {
  id              String   @id @default(cuid())
  investorId      String   @unique
  name            String
  investorType    String
  commitmentMm    Decimal
  calledCapitalMm Decimal?
  distributedMm   Decimal?
  navMm           Decimal?
  domicile        String
  entityName      String?
  status          String   @default("Active")
  contactName     String?
  contactEmail    String?
  taxExempt       Boolean  @default(false)
  erisa           Boolean  @default(false)
  k1Status        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Security {
  id             String    @id @default(cuid())
  securityId     String    @unique
  name           String
  securityType   String
  issuer         String?
  ticker         String?
  cusip          String?
  isin           String?
  currency       String    @default("USD")
  marketValue    Decimal?
  costBasis      Decimal?
  quantity       Decimal?
  unrealizedGain Decimal?
  sector         String?
  country        String?
  maturityDate   DateTime?
  pricePerUnit   Decimal?
  lastPriceDate  DateTime?
  ratingAgency   String?
  creditRating   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ──────────────────────────────────────────────
// TASK & WORKFLOW MODELS
// ──────────────────────────────────────────────

model TaskDefinition {
  id               String           @id @default(cuid())
  taskCode         String           @unique
  name             String
  description      String
  category         String
  frequency        String
  estimatedMinutes Int
  priority         String
  department       String
  steps            String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  assignments      TaskAssignment[]
}

model TaskAssignment {
  id               String          @id @default(cuid())
  taskDefinitionId String
  taskDefinition   TaskDefinition  @relation(fields: [taskDefinitionId], references: [id])
  entityName       String
  assignedToId     String?
  assignedTo       InternalUser?   @relation(fields: [assignedToId], references: [id])
  status           String          @default("Not Started")
  dueDate          DateTime
  completedDate    DateTime?
  periodEnd        String
  priority         String
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

// ──────────────────────────────────────────────
// AI & AGENTS
// ──────────────────────────────────────────────

model AISkill {
  id                String    @id @default(cuid())
  name              String
  description       String
  category          String
  status            String    @default("Active")
  accuracy          Decimal?
  model             String
  lastRun           DateTime?
  runCount          Int       @default(0)
  avgProcessingTime String?
  inputType         String
  outputType        String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Agent {
  id            String   @id @default(cuid())
  name          String
  description   String
  category      String
  provider      String
  status        String   @default("Available")
  rating        Decimal?
  reviewCount   Int      @default(0)
  monthlyPrice  Decimal?
  capabilities  String
  integrations  String
  avgTimeSaved  String?
  accuracy      Decimal?
  icon          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ──────────────────────────────────────────────
// PEOPLE — SUPER GRANULAR INTERNAL USER MODEL
// 300+ fields tracking everything about staff
// ──────────────────────────────────────────────

