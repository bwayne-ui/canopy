  entityName      String
  fundName        String
  effectiveDate   String
  transactionDate String
  transactionType String
  amount          Float
  debitCredit     String
  investorId      String
  accountRef      String
  memo            String     @default("")
  externalRef     String     @default("")
  batch           WfDiuBatch @relation(fields: [batchId], references: [id])
}

model WfAuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actor      String   @default("system")
  before     String?
  after      String?
  note       String?
  createdAt  DateTime @default(now())
}

// ============================================================
// Revenue Ops — Quote-to-Cash (Salesforce replacement)
// ============================================================

model Account {
  id                  String        @id @default(cuid())
  accountId           String        @unique
  name                String
  domain              String?
  industry            String?
  hqCity              String?
  hqState             String?
  hqCountry           String?
  region              String?
  employeeCount       Int?
  aumMm               Decimal?
  website             String?
  linkedInUrl         String?
  description         String?
  notes               String?
  status              String        @default("Prospect")
  ownerId             String?
  ownerName           String?
  convertedToClientId String?
  clientId            String?       // FK to Client.id — populated for Active Client accounts
  tags                String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  contacts            Contact[]
  opportunities       Opportunity[]
  activities          Activity[]
  contracts           Contract[]
}

model Contact {
  id               String               @id @default(cuid())
  contactId        String               @unique
  firstName        String
  lastName         String
  title            String?
  email            String?
  phone            String?
  mobilePhone      String?
  linkedInUrl      String?
  accountId        String?
  accountName      String?
  isPrimary        Boolean              @default(false)
  contactType      String               @default("Contact")
  department       String?
  status           String               @default("Active")
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  account          Account?             @relation(fields: [accountId], references: [id])
  opportunityRoles OpportunityContact[]
  activities       Activity[]
}

model Lead {
  id                     String    @id @default(cuid())
  leadId                 String    @unique
  firstName              String
  lastName               String
  email                  String?
  phone                  String?
  company                String?
  title                  String?
  leadSource             String    @default("Inbound")
  status                 String    @default("New")
  ownerId                String?
  ownerName              String?
  notes                  String?
  assignedAt             DateTime?
  convertedAt            DateTime?
  convertedAccountId     String?
  convertedContactId     String?
  convertedOpportunityId String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Opportunity {
  id              String               @id @default(cuid())
  opportunityId   String               @unique
  name            String
  accountId       String?
  accountName     String
  stage           String               @default("Prospecting")
  probability     Int                  @default(10)
  closeDate       DateTime?
  amount          Decimal?
  tcv             Decimal?
  currency        String               @default("USD")
  ownerId         String?
  ownerName       String?
  description     String?
  lostReason      String?
  competitorNotes String?
  nextStepDate    DateTime?
  nextStepNote    String?
  leadSource      String?
  entityCount     Int?
  aumMm           Decimal?
  fundStrategies  String?
  scopeNotes      String?
  closedAt        DateTime?
  clientId        String?       // FK to Client.id — set for Expansion deals on existing clients
  clientName      String?       // denormalized client name for expansion deals
  dealType        String        @default("New Logo") // New Logo | Expansion
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  account         Account?             @relation(fields: [accountId], references: [id])
  contacts        OpportunityContact[]
  activities      Activity[]
  quotes          Quote[]
  contracts       Contract[]
}

model OpportunityContact {
  id            String      @id @default(cuid())
  opportunityId String
  contactId     String
  role          String      @default("Contact")
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, contactId])
}

model Activity {
  id              String       @id @default(cuid())
  activityId      String       @unique
  type            String       @default("Note")
  subject         String
  description     String?
  outcome         String?
  direction       String?
  durationMinutes Int?
  activityDate    DateTime     @default(now())
  accountId       String?
  accountName     String?
  contactId       String?
  contactName     String?
  opportunityId   String?
  opportunityName String?
  ownerId         String?
  ownerName       String?
  nextStepDate    DateTime?
  completed       Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  account         Account?     @relation(fields: [accountId], references: [id])
  contact         Contact?     @relation(fields: [contactId], references: [id])
  opportunity     Opportunity? @relation(fields: [opportunityId], references: [id])
}

model Quote {
  id              String      @id @default(cuid())
  quoteId         String      @unique
  name            String
  opportunityId   String?
  opportunityName String?
  accountId       String?
  accountName     String
  status          String      @default("Draft")
  validUntil      DateTime?
  currency        String      @default("USD")
  totalArr        Decimal?
  totalTcv        Decimal?
  discountPct     Decimal?
  discountReason  String?
  notes           String?
  sentAt          DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  createdById     String?
  createdByName   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  opportunity     Opportunity? @relation(fields: [opportunityId], references: [id])
  lines           QuoteLine[]
}

model QuoteLine {
  id                String    @id @default(cuid())
  quoteId           String
  service           String
  description       String?
  aumTierLabel      String?
  aumTierMin        Decimal?
  aumTierMax        Decimal?
  pricePerEntity    Decimal?
  estimatedEntities Int?
  annualValue       Decimal?
  notes             String?
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  quote             Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model PriceBook {
  id             String   @id @default(cuid())
  service        String
  aumTierLabel   String
  aumTierMin     Decimal?
  aumTierMax     Decimal?
  pricePerEntity Decimal
  effectiveDate  DateTime @default(now())
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Contract {
  id                    String       @id @default(cuid())
  contractId            String       @unique
  name                  String
  opportunityId         String?
  accountId             String?
  accountName           String
  status                String       @default("Draft")
  contractType          String       @default("MSA")
  startDate             DateTime?
  endDate               DateTime?
  autoRenew             Boolean      @default(false)
  noticePeriodDays      Int?
  totalValue            Decimal?
  annualValue           Decimal?
  paymentTerms          String?
  billingFrequency      String       @default("Quarterly")
  signedDate            DateTime?
  executedDate          DateTime?
  counterpartySignatory String?
  jsqSignatory          String?
  documentRef           String?
  notes                 String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  opportunity           Opportunity? @relation(fields: [opportunityId], references: [id])
  account               Account?     @relation(fields: [accountId], references: [id])
  orders                Order[]
}

model Order {
  id               String    @id @default(cuid())
  orderId          String    @unique
  contractId       String?
  accountId        String?
  accountName      String
  status           String    @default("Pending")
  billingStartDate DateTime?
  billingEndDate   DateTime?
  annualValue      Decimal?
  billingFrequency String    @default("Quarterly")
  nextBillingDate  DateTime?
  entityCount      Int?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  contract         Contract? @relation(fields: [contractId], references: [id])
}

// ============================================================
// Deal Capture Form (DCF) — intake form submitted by prospects
// Each submission is linked to an Opportunity. Most detail lives
// in DcfEntity (one row per fund/entity in the mandate).
// ============================================================

model DcfSubmission {
  id                          String           @id @default(cuid())
  dcfId                       String           @unique   // DCF-2024-001
  opportunityId               String?          // FK to Opportunity.id
  opportunityName             String?
  accountId                   String?          // FK to Account.id
  accountName                 String?
  status                      String           @default("Draft")
  // Draft | Submitted | Under Review | Complete | Rejected
  submittedAt                 DateTime?
  reviewedAt                  DateTime?
  reviewedBy                  String?

  // Submitter (from "Your Information" section)
  contactFirstName            String?
  contactLastName             String?
  contactEmail                String?
  contactTitle                String?

  // General org questions
  financeOutsourced           Boolean          @default(false)
  financeOutsourcedNotes      String?
  prevAdminExperience         Boolean          @default(false)
  prevAdminExperienceNotes    String?

  // Current admin technology
  adminTechCompany            String?
  adminTechProduct            String?
  adminTechDetails            String?

  // Language/locale preferences
  preferredLanguage           String           @default("English")
  preferredDateFormat         String           @default("MM-DD-YYYY")
  autoTimezone                Boolean          @default(true)

  // Internal notes / review
  internalNotes               String?

  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt

  advisors                    DcfAdvisor[]
  entities                    DcfEntity[]
  bankAccounts                DcfBankAccount[]
  integrations                DcfIntegration[]
}

// Service providers/advisors attached to a DCF submission
// advisorType: Legal | Bank | Current Admin | Tax | Auditor
model DcfAdvisor {
  id              String        @id @default(cuid())
  dcfSubmissionId String
  advisorType     String        // Legal | Bank | Current Admin | Tax | Auditor
  firstName       String?
  lastName        String?
  firmName        String?
  email           String?
  details         String?
  createdAt       DateTime      @default(now())
  submission      DcfSubmission @relation(fields: [dcfSubmissionId], references: [id], onDelete: Cascade)
}

// Per-entity/fund detail — one row per fund entity in the mandate.
// Maps to the entity-scoped sections of the DCF (Fund Info, Fund Size,
// Investor Info, Investment Info, Allocation, Capital Activity,
// Reporting, Other Services, GP Entities, Data Migration).
model DcfEntity {
  id                          String        @id @default(cuid())
  dcfSubmissionId             String
  entityName                  String        // name as entered on the form
  entityId                    String?       // FK to Entity.id if matched post-intake
  sortOrder                   Int           @default(0)

  // ── Fund Information ────────────────────────────────────────────
  jurisdiction                String?       // e.g. "Cayman Islands", "Delaware"
  vintageYear                 Int?
  entityType                  String?       // PE | VC | RE | Credit | FoF | CLO | SMA | Co-Invest | Other
  firstCapitalCallDate        DateTime?
  expectedLaunchDate          DateTime?     // new funds only
  gpLegalName                 String?
  gpSupportNeeded             Boolean       @default(false)
  lineOfCredit                Boolean       @default(false)
  fundLevelLeverage           Boolean       @default(false)
  futureRaising               String?

  // ── Fund Size ───────────────────────────────────────────────────
  currentCommittedCapitalMm   Decimal?
  targetCommittedCapitalMm    Decimal?
  twelveMonthTargetMm         Decimal?      // open-end only
  currentCalledCapitalMm      Decimal?
  expectedFirstCallDate       DateTime?     // if none called yet

  // ── Investor Information ────────────────────────────────────────
  currentInvestorCount        Int?
  targetInvestorCount         Int?
  nonUsInvestorCount          Int?
  subscriptionDocsReceived    Int?          // new funds
  redemptionFrequency         String?       // open-end: Monthly | Quarterly | Annually
  sideLetterFeeClasses        Int?
  digitalSubscriptionConcerns Boolean       @default(false)

  // ── Investment Information ──────────────────────────────────────
  currentInvestmentCount      Int?
  expectedTotalInvestments    Int?
  expectedDebtInvestments     Int?
  ventureStage                String?       // Seed | Early | Growth | Late
  fofMethodology              String?
  realEstateAcctMethod        String?       // Operating | Non-operating
  debtLoanOrigination         String?
  debtAmortizationMethod      String?
  avgLoanSizeMm               Decimal?
  drawdownPct                 Decimal?
  investmentAdditionalContext String?

  // ── Allocation Information ──────────────────────────────────────
  proRataStructure            Boolean       @default(true)
  managementFeeCalc           String?
  managementFeeWaiver         Boolean       @default(false)
  waterfallType               String?       // European | American | Other

  // ── Capital Activity & Treasury ────────────────────────────────
  annualCallsDistributions    Int?
  monthlyWires                Int?
  monthlyAch                  Int?
  processFundInvoices         Boolean       @default(false)
  initiateAcquisitionFunding  Boolean       @default(false)

  // ── Reporting Information ───────────────────────────────────────
  firstReportingQuarter       String?       // e.g. "Q1 2025"
  reportingCurrency           String?       @default("USD")
  accountingStandard          String?       // US GAAP | IFRS | Other
  reportingFrequency          String?       // Monthly | Quarterly | Annually | Other
  valuationDeliveryFrequency  String?
  reportingDeadlineDays       Int?
  quarterlyFootnotes          Boolean       @default(false)
  auditLiaisonSupport         Boolean       @default(false)
  regulatoryReportingSupport  String?

  // ── Other Service Support ───────────────────────────────────────
  support1099                 Boolean       @default(false)
  investorWatchlistScreenings Boolean       @default(false)

  // ── GP Entities / Carry Vehicles ───────────────────────────────
  customizedReportingRequired Boolean       @default(false)

  // ── Data Migration ──────────────────────────────────────────────
  migrationApproach           String?       // Full | Point in Time | Hybrid
  currentDataStorage          String?       // Excel | QuickBooks | Other
  migrateHistoricalDocs       Boolean       @default(false)
  investorDataAvailable       Boolean       @default(false)

  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  submission                  DcfSubmission @relation(fields: [dcfSubmissionId], references: [id], onDelete: Cascade)
}

model DcfBankAccount {
  id              String        @id @default(cuid())
  dcfSubmissionId String
  bankName        String
  details         String?
  createdAt       DateTime      @default(now())
  submission      DcfSubmission @relation(fields: [dcfSubmissionId], references: [id], onDelete: Cascade)
}

model DcfIntegration {
  id              String        @id @default(cuid())
  dcfSubmissionId String
  applicationName String
  details         String?
  createdAt       DateTime      @default(now())
  submission      DcfSubmission @relation(fields: [dcfSubmissionId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// LOGIN GATE (prototype access control)
// ──────────────────────────────────────────────

model LoginAttempt {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  emailLower    String
  domain        String
  domainAllowed Boolean
  outcome       String
  ipAddress     String?
  userAgent     String?

  @@index([createdAt])
  @@index([outcome])
  @@index([domainAllowed])
}
