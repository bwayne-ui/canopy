generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// CORE DOMAIN MODELS
// ──────────────────────────────────────────────

model Client {
  id                String   @id @default(cuid())
  name              String
  shortName         String?
  primaryStrategy   String
  hqCity            String
  hqCountry         String
  region            String
  relationshipStart DateTime?
  status            String   @default("Active")
  totalEntities     Int      @default(0)
  totalNavMm        Decimal  @default(0)
  totalCommitmentMm Decimal  @default(0)
  revenueL12m       Decimal  @default(0)
  marginPct         Decimal  @default(0)
  teamLead          String
  podId             String?
  serviceLine       String
  yearFounded       Int?
  employeeCount     Int?
  website           String?
  notes             String?

  // ── STRATEGY & AUM ──
  aumMm                 Float?
  strategyMix           String?   // comma-separated, e.g. "Buyout,Growth,Credit"
  portfolioCompanyCount Int?
  typicalDealSizeMm     Float?
  firstFundVintage      Int?
  latestFundVintage     Int?

  // ── FUND STRUCTURE DEFAULTS ──
  waterfallType         String?   // "European" | "American"
  hurdleRatePct         Float?
  mgmtFeePct            Float?
  carriedInterestPct    Float?
  gpCommitPct           Float?

  // ── OPERATIONAL PARTNERS ──
  auditFirm             String?
  legalCounsel          String?
  primaryCustodian      String?
  taxAdvisor            String?
  bankingRelationship   String?
  dataRoomPlatform      String?

  // ── COMPLIANCE ──
  secRegistered         Boolean?
  advFilingDate         DateTime?
  formPfRequired        Boolean?
  amlRiskTier           String?   // "Low" | "Medium" | "High"

  // ── RELATIONSHIP / CRM ──
  relationshipStage     String?   // prospect stage: "Qualified" | "Proposal" | "Negotiation" | "Verbal"
  churnDate             DateTime?
  churnReason           String?
  lastContactAt         DateTime?
  nextMeetingAt         DateTime?
  accountExecutive      String?
  nps                   Int?

  // ── SERVICE MIX ──
  usesFundAdmin         Boolean?
  usesInvestorPortal    Boolean?
  usesTaxServices       Boolean?
  usesComplianceSupport Boolean?
  usesTreasuryServices  Boolean?

  // ── BILLING ──
  billingFrequency      String?   // "Monthly" | "Quarterly" | "Annually"
  arAgingDays           Int?
  lastInvoiceAt         DateTime?
  paymentMethod         String?   // "ACH" | "Wire" | "Check"

  // ── ESG ──
  esgPolicy             Boolean?
  diversityReporting    Boolean?
  sasbAligned           Boolean?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  entities          Entity[]
}

model Entity {
  id                   String   @id @default(cuid())
  entityId             String   @unique
  name                 String
  entityType           String
  structureType        String
  domicile             String
  strategy             String
  vintage              Int?
  openEnded            Boolean  @default(false)
  lifecycleStatus      String
  clientId             String
  client               Client   @relation(fields: [clientId], references: [id])
  commitmentMm         Decimal?
  calledCapitalMm      Decimal?
  distributedCapitalMm Decimal?
  navMm                Decimal?
  unfundedMm           Decimal?
  prefRatePct          Decimal?
  carryPct             Decimal?
  mgmtFeePct           Decimal?
  waterfallType        String?
  grossIrrPct          Decimal?
  netIrrPct            Decimal?
  moic                 Decimal?
  tvpi                 Decimal?
  dpi                  Decimal?
  revenueL12m          Decimal?
  costL12m             Decimal?
  marginPct            Decimal?
  accountingSystem     String?
  administrator        String?
  auditor              String?
  legalCounsel         String?
  reportingFrequency   String?
  navFrequency         String?
  currency             String   @default("USD")
  inceptionDate        DateTime?
  hqCity               String?
  region               String?
  dataQualityScore     Decimal?
  confidenceScore      Decimal?
  fundFamilyTags       String?       // JSON array of tag strings, e.g. '["#WalkerComplex","#SPVs"]'
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // ── GENERAL / ENTITY PROFILE ──
  assetClass                     String?
  shortName                      String?
  domicileCountry                String?
  domicileCountryOther           String?
  domicileState                  String?
  einTaxId                       String?
  entityRole                     String?
  entityRoleOther                String?
  entityTypeOther                String?
  fundStructure                  String?
  fundStructureOther             String?
  regulatoryClassification       String?
  regulatoryClassificationOther  String?
  geographyFocus                 String?   // JSON array
  geographyFocusOther            String?
  sectorFocus                    String?   // JSON array
  sectorFocusOther               String?
  investmentStrategyDetail       String?
  investmentStrategyDetailOther  String?
  leveredFund                    Boolean?
  usesSubFacility                Boolean?
  targetCommittedCapital         Decimal?
  targetInvestmentCount          Int?
  targetInvestorCount            Int?
  targetLeveragePct              Decimal?
  fundraisingFirstClose          DateTime?
  fundraisingFinalClose          DateTime?
  registeredAddress              String?

  // ── ECONOMICS / FEES & CARRY ──
  carryStructure                 String?
  catchUpType                    String?
  clawbackApplies                Boolean?
  clawbackTrueUpFrequency        String?
  feeStepdownExists              Boolean?
  hurdleType                     String?
  mgmtFeeBasis                   String?
  mgmtFeeBasisOther              String?
  mgmtFeeFrequency               String?
  mgmtFeeWaiverOffset            String?
  mgmtFeeWaiverOffsetOther       String?
  escrowHoldbackApplies          Boolean?
  escrowHoldbackPct              Decimal?
  mgmtFeeOffsetPct               Decimal?
  prefReturnCompounding          String?
  prefReturnDayCount             String?
  taxDistributionPolicy          String?
  taxDistributionPolicyOther     String?
  unitOfAccount                  String?

  // ── FUND ACCOUNTING — OPERATIONS ──
  booksComplexityTier            String?
  chartOfAccountsTemplate        String?
  chartOfAccountsOther           String?
  generalLedgerSystem            String?
  generalLedgerSystemOther       String?
  closeProcessModel              String?
  bankFeedEnabled                Boolean?
  portfolioDataFeedEnabled       Boolean?
  docMgmtSystem                  String?
  docMgmtSystemOther             String?
  multiCloseRebalancing          String?
  reconciliationTool             String?
  reconciliationToolOther        String?
  sideLetterComplexity           String?
  specialAllocationFrequency     String?
  waterfallCalcAutomation        String?
  annualCapitalEventsExpected    String?

  // ── FUND ACCOUNTING — ONBOARDING ──
  conversionType                 String?
  conversionStartDate            DateTime?
  documentConversionScope        String?
  onboardingOwner                String?
  sourceSystemsPriorAdmin        String?   // JSON array
  sourceSystemsPriorAdminOther   String?

  // ── FUND ACCOUNTING — REPORTING ──
  accountingFramework            String?
  accountingFrameworkOther       String?
  financialStatementsFrequency   String?
  footnoteDisclosureLevel        String?
  investorStatementsFrequency    String?
  reportingPackageTimingQeDays   Int?
  reportingPackageTimingYeDays   Int?
  valuationDeliverySla           Int?

  // ── INVESTOR SERVICES — COMPLIANCE ──
  amlProgramRequired             Boolean?
  fatcaRequired                  Boolean?
  crsRequired                    Boolean?
  kycStandard                    String?
  kycStandardOther               String?
  benefitPlanInvestorTracking    Boolean?
  restrictedPersonsTracking      Boolean?
  support1099Level               String?

  // ── INVESTOR SERVICES — TREASURY OPS ──
  bankAccountCount               Int?
  bankConnectivityMethod         String?
  bankConnectivityOther          String?
  multiCurrency                  Boolean?
  paymentApprovalLevels          String?
  positivePayEnabled             Boolean?
  primaryCurrency                String?
  primaryCurrencyOther           String?

  // ── INVESTOR SERVICES — OPERATIONS ──
  investorPortalEnabled          Boolean?
  redemptionProcessingModel      String?
  sideLetterWorkflowAutomation   String?

  // ── SCOPE / MODULES ──
  scopeFundAccounting            Boolean?
  scopeInvestorServices          Boolean?
  scopeTaxServices               String?
  scopeTaxServicesOther          String?
  scopeTreasury                  Boolean?
  scopeLoanAdmin                 Boolean?
  scopeMgmtCoAccounting          Boolean?
  scopeRegulatoryReporting       Boolean?
  scopeAmlKyc                    String?
  scopeFatcaCrs                  Boolean?

  // ── GOVERNANCE ──
  auditTrailEnabled              Boolean?
  dataClassificationLevel        String?
  entityDataSteward              String?

  // ── RELATIONSHIPS ──
  custodianPrimeBroker           String?
  fundComplexName                String?
  managementCompanyRef           String?
  sponsorGpOrg                   String?
  taxPreparer                    String?

  // ── DOMAIN TABLE RELATIONS ──
  creditDomain                   CreditDomainFields?
  reDomain                       REDomainFields?
  oefDomain                      OEFDomainFields?
  vcDomain                       VCDomainFields?
  peDomain                       PEDomainFields?
  fofDomain                      FOFDomainFields?
  gpCarryDomain                  GPCarryDomainFields?
  manCoDomain                    ManCoDomainFields?
  otherDomain                    OtherDomainFields?
  securityLinks                  SecurityEntityLink[]
  wfFund                         WfFund?
}

// ──────────────────────────────────────────────
// DOMAIN-SPECIFIC TABLES (1:1 with Entity)
// ──────────────────────────────────────────────

model CreditDomainFields {
  id                          String  @id @default(cuid())
  entityId                    String  @unique
  entity                      Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  loanTypeMix                 String?   // JSON array
  loanTypeMixOther            String?
  collateralTypeMix           String?   // JSON array
  collateralTypeMixOther      String?
  covenantMonitoringRequired  Boolean?
  covenantFrequency           String?
  facilityComplexityTier      String?
  indexType                   String?
  indexTypeOther              String?
  interestDayCalcMethod       String?
  interestDayCalcOther        String?
  paymentFrequency            String?
  paymentFrequencyOther       String?
  pikInterestPresence         Boolean?
  delayedDrawPresence         Boolean?
  revolverPresence            Boolean?
  oidUpfrontFeesPresence      Boolean?
  prepaymentPenaltyPresence   Boolean?
  prepaymentPenaltyType       String?
  prepaymentPenaltyOther      String?
  loanServicingSystem         String?
  loanServicingSystemOther    String?
  workoutRestructuringActivity String?
}

model REDomainFields {
  id                          String  @id @default(cuid())
  entityId                    String  @unique
  entity                      Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  propertyTypeMix             String?   // JSON array
  propertyTypeMixOther        String?
  propertyCount               String?
  debtFacilityCount           Int?
  leaseCount                  Int?
  stabilizedVsDevelopment     String?
  geographicDispersion        String?
  propertyManagerModel        String?
  propertyDebtExists          Boolean?
  preferredEquityInstruments  Boolean?
  appraisalFrequency          String?
  appraisalFrequencyOther     String?
  camReconciliationsRequired  Boolean?
  capexBudgetingRequired      Boolean?
  constructionDrawsPresence   Boolean?
  constructionDrawFrequency   String?
  energyEsgReportingRequired  Boolean?
  insuranceTrackingRequired   Boolean?
  leaseAbstractingRequired    Boolean?
  noiTrackingRequired         Boolean?
  occupancyReportingRequired  Boolean?
  rentRollDeliveryFrequency   String?
  reJointVentureAccounting    Boolean?
  waterfallAtPropertyLevel    Boolean?
  tenantConcentrationRisk     String?
  valuationMethodMix          String?   // JSON array
}

model OEFDomainFields {
  id                                String  @id @default(cuid())
  entityId                          String  @unique
  entity                            Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  unitizedFund                      Boolean?
  numberOfShareClasses              Int?
  shareClassNames                   String?
  subscriptionWindow                String?
  redemptionWindow                  String?
  lockupPeriodMonths                Int?
  gateApplies                       Boolean?
  gatePct                           Decimal?
  dripOffered                       Boolean?
  crystallizationTiming             String?
  crystallizationBasis              String?
  strategyType                      String?
  primeBrokerCount                  Int?
  counterpartyCount                 Int?
  otcExposurePresence               Boolean?
  dailyNavRequired                  Boolean?
  investorLiquidityTerms            String?
  sidePocketUsage                   Boolean?
  highWaterMarkTrackingRequired     Boolean?
  incentiveFeeFrequency             String?
  equalizationMethod                String?
  lossCarryforwardTrackingRequired  Boolean?
}

model VCDomainFields {
  id                              String  @id @default(cuid())
  entityId                        String  @unique
  entity                          Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  stageFocusMix                   String?   // JSON array
  safeConvertibleNotePresence     Boolean?
  bridgeFinancingFrequency        String?
  warrantOrTokenExposure          String?
  optionPoolTrackingRequired      Boolean?
  liquidationPreferenceStructures String?
  payToPlayClausesPresent         Boolean?
}

model PEDomainFields {
  id                              String  @id @default(cuid())
  entityId                        String  @unique
  entity                          Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  averageAddOnCountPerPlatform    Int?
  coInvestAllocationFrequency     String?
  portfolioLevelLeveragePresence  Boolean?
  pikToggleDebtPresence           Boolean?
}

model FOFDomainFields {
  id                          String  @id @default(cuid())
  entityId                    String  @unique
  entity                      Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  underlyingFundCount         Int?
  lookThroughRequired         Boolean?
  underlyingCarryTransparency String?
}

model GPCarryDomainFields {
  id                            String  @id @default(cuid())
  entityId                      String  @unique
  entity                        Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  gpMemberCount                 Int?
  allocationVariability         String?
  clawbackAllocationMethod      String?
  cashlessContributionsPresence Boolean?
  deferredCompensationLinked    Boolean?
  vestingScheduleComplexity     String?
}

model ManCoDomainFields {
  id                              String  @id @default(cuid())
  entityId                        String  @unique
  entity                          Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  revenueStreamsMonitoringFees    Boolean?
  revenueStreamsTransactionFees   Boolean?
  revenueStreamsConsultingFees    Boolean?
  revenueStreamsOther             String?
  feeOffsetPctToFund             Decimal?
  costSharingWithGp              Boolean?
  sharedExpenseAllocationMethod  String?
  intercompanyBillingFrequency   String?
  payrollJurisdictions           String?   // JSON array
}

model OtherDomainFields {
  id                          String  @id @default(cuid())
  entityId                    String  @unique
  entity                      Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  historicalErrorRatePct       Decimal?
  avgInvestorQueryVolumeMonth  Int?
  customReportingRequests      String?
  boardReportingRequired       Boolean?
  esgReportingRequired         Boolean?
  ilpaTemplateRequired         Boolean?
  investorConcentrationPct     Decimal?
  top3LpConcentrationPct       Decimal?
  strategicAccountFlag         Boolean?
}

model Investor {
  id              String   @id @default(cuid())
  investorId      String   @unique
  name            String
  investorType    String
  commitmentMm    Decimal
  calledCapitalMm Decimal?
  distributedMm   Decimal?
  navMm           Decimal?
  domicile        String
  entityName      String?
  status          String   @default("Active")
  contactName     String?
  contactEmail    String?
  taxExempt       Boolean  @default(false)
  erisa           Boolean  @default(false)
  k1Status        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Security {
  id             String    @id @default(cuid())
  securityId     String    @unique
  name           String
  securityType   String
  issuer         String?
  ticker         String?
  cusip          String?
  isin           String?
  currency       String    @default("USD")
  marketValue    Decimal?
  costBasis      Decimal?
  quantity       Decimal?
  unrealizedGain Decimal?
  sector         String?
  country        String?
  maturityDate   DateTime?
  pricePerUnit   Decimal?
  lastPriceDate  DateTime?
  ratingAgency   String?
  creditRating   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  entityLinks    SecurityEntityLink[]
}

// ──────────────────────────────────────────────
// EMPLOYEE → ENTITY / CLIENT ASSIGNMENTS
// Drives capacity planning & auto-assignment
// ──────────────────────────────────────────────

model EmployeeEntityAssignment {
  id           String       @id @default(cuid())
  employeeId   String
  employee     InternalUser @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  entityName   String?      // denormalized, matches TaskAssignment.entityName
  clientName   String?      // GP/client name
  department   String       // e.g. "Fund Accounting"
  serviceLine  String       // e.g. "NAV Calculation"
  role         String       // "Primary" | "Secondary"
  coveragePct  Float        @default(100)
  startDate    DateTime?
  status       String       @default("Active")
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model SecurityEntityLink {
  id                     String   @id @default(cuid())
  securityId             String
  security               Security @relation(fields: [securityId], references: [id], onDelete: Cascade)
  entityId               String
  entity                 Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  // ── Client-specific naming & classification
  financialStatementName String?
  clientNickname         String?
  // ── Deal / investment details
  dealPartner            String?
  investmentThesis       String?
  acquisitionDate        DateTime?
  exitDate               DateTime?
  // ── Economics
  costAtAcquisition      Decimal?
  currentCarryingValue   Decimal?
  ownershipPct           Decimal?
  // ── Operational
  isActiveholding        Boolean  @default(true)
  watchlistFlag          Boolean  @default(false)
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([securityId, entityId])
}

// ──────────────────────────────────────────────
// TASK & WORKFLOW MODELS
// ──────────────────────────────────────────────

model TaskDefinition {
  id               String           @id @default(cuid())
  taskCode         String           @unique
  name             String
  description      String
  category         String
  frequency        String
  estimatedMinutes Int
  priority         String
  department       String
  steps            String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  assignments      TaskAssignment[]
}

model TaskAssignment {
  id               String          @id @default(cuid())
  taskDefinitionId String
  taskDefinition   TaskDefinition  @relation(fields: [taskDefinitionId], references: [id])
  entityName       String
  assignedToId     String?
  assignedTo       InternalUser?   @relation(fields: [assignedToId], references: [id])
  assignees        String?         // JSON: [{employeeId, employeeName, role: "Primary"|"Secondary"}]
  status           String          @default("Not Started")
  dueDate          DateTime
  completedDate    DateTime?
  periodEnd        String
  priority         String
  notes            String?
  stepCompletions  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

// ──────────────────────────────────────────────
// AI & AGENTS
// ──────────────────────────────────────────────

model AISkill {
  id                String    @id @default(cuid())
  name              String
  description       String
  category          String
  status            String    @default("Active")
  accuracy          Decimal?
  model             String
  lastRun           DateTime?
  runCount          Int       @default(0)
  avgProcessingTime String?
  inputType         String
  outputType        String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Agent {
  id            String   @id @default(cuid())
  name          String
  description   String
  category      String
  provider      String
  status        String   @default("Available")
  rating        Decimal?
  reviewCount   Int      @default(0)
  monthlyPrice  Decimal?
  capabilities  String
  integrations  String
  avgTimeSaved  String?
  accuracy      Decimal?
  icon          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ──────────────────────────────────────────────
// PEOPLE — SUPER GRANULAR INTERNAL USER MODEL
// 300+ fields tracking everything about staff
// ──────────────────────────────────────────────

