  fundName    String
  status      String              @default("generated")
  generatedAt DateTime            @default(now())
  postedAt    DateTime?
  refreshedAt DateTime?
  totalLines  Int                 @default(0)
  totalAmount Float               @default(0)
  fileContent String              @default("")
