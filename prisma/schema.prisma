// ──────────────────────────────────────────────
// REPORTS — query-logic library, reusable, permissioned
// ──────────────────────────────────────────────

model Report {
  id              String      @id @default(cuid())
  reportId        String      @unique               // RPT-001 etc.
  name            String
  description     String?
  category        String                            // NAV, Tax, Compliance, Portfolio, …
  department      String      @default("Fund Accounting") // Owning team: Fund Accounting, Investor Services, Finance, Billing, Corp Accounting, Rev Ops, Fund Admin Onboarding, Tax, Legal, Compliance, Treasury
  format          String      @default("PDF")       // PDF, Excel, Dashboard, XML, JSON
  frequency       String      @default("On-Demand") // Monthly, Quarterly, Annually, On-Demand, Weekly
  recipients      String?                           // free-text, comma-sep
  // Reusable query logic
  querySource     String      @default("prisma")    // prisma | sql | skill | composite
  queryLogic      String                            // JSON: { model, where, select, … } OR raw SQL OR skill name
  // Parameters the user can edit at run time. JSON schema-ish.
  parametersSchema String?                          // JSON-encoded array of { name, type, default, required, options? }
  // Permissioning
  ownerId         String                            // InternalUser.id
  ownerName       String?
  visibility      String      @default("Private")   // Private | Team | Org | Public
  sharedWithRoles String?                           // JSON array of role strings
  sharedWithUsers String?                           // JSON array of InternalUser ids
  minGrade        String?                           // Entitlement: P1..P5 (IC) or M2..M6 (Mgmt). Null = open.
  exportFormats   String   @default("csv,json,xml,html,xlsx") // comma-sep allowed export formats
  // Lifecycle
  status          String      @default("Active")    // Draft | Active | Archived | Deprecated
  version         String      @default("1.0.0")
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  runCount        Int         @default(0)
  tags            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  runs            ReportRun[]
}

model ReportRun {
  id            String   @id @default(cuid())
  runId         String   @unique
  reportId      String
  report        Report   @relation(fields: [reportId], references: [id])
  triggeredById String                     // InternalUser.id
  triggeredBy   String                     // display name
  parameters    String                     // JSON snapshot of params used
  status        String   @default("Queued") // Queued | Running | Success | Failed | Blocked
  rowCount      Int?
  durationMs    Int?
  outputRef     String?                    // path or URL to artifact
  error         String?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
}

// ──────────────────────────────────────────────
// TIME TRACKING — staff timesheets
// ──────────────────────────────────────────────

model Timesheet {
  id           String           @id @default(cuid())
  timesheetId  String           @unique
  userId       String                                // InternalUser.id
  userName     String
  weekStarting DateTime                              // Monday of the week (UTC midnight)
  status       String           @default("Draft")    // Draft | Submitted | Approved | Rejected
  totalHours   Decimal          @default(0)
  billableHours Decimal         @default(0)
  utilizationPct Decimal?
  submittedAt  DateTime?
  approvedAt   DateTime?
  approvedById String?
  approvedByName String?
  rejectedReason String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  entries      TimesheetEntry[]
}

model TimesheetEntry {
  id           String    @id @default(cuid())
  timesheetId  String
  timesheet    Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  date         DateTime                              // the day this entry covers
  clientName   String?                               // GP — optional
  entityName   String?                               // Fund — optional
  projectName  String?                               // Project — optional
  taskCode     String?                               // links to TaskDefinition.taskCode
  category     String                                // Billable | Non-Billable | Overhead | PTO | Sick | Holiday
  description  String
  hours        Decimal                               // 0.25 increments expected
  billable     Boolean   @default(true)
  billRate     Decimal?
  approved     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ──────────────────────────────────────────────
// TRANSACTION PARAMETERS (ILPA-aligned config)
// ──────────────────────────────────────────────

model TransactionParameter {
  id                  String   @id @default(cuid())
  code                String   @unique          // e.g. CC-INV, DIST-ROC
  name                String                    // Full display name
  ilpaCategory        String                    // Capital Call | Distribution | Fee & Expense | Carried Interest | Facility/Debt | Other
  ilpaSubtype         String?                   // ILPA template sub-classification string
  ilpaTemplateRef     String?                   // ILPA template version reference
  direction           String                    // Inflow | Outflow | Bilateral | N/A
  insideFund          Boolean  @default(true)   // true = Inside Fund per ILPA Sept 2025 CC&D
  recallable          Boolean  @default(false)  // Recallable distribution flag
  navImpact           String                    // Increase NAV | Decrease NAV | No NAV Impact | GP Allocation
  glDebit             String?                   // Investran GL debit account
  glCredit            String?                   // Investran GL credit account
  journalType         String?                   // JE type code (e.g. JE-CC, JE-DIST)
  perfTemplateClass   String?                   // ILPA Perf Template class: Contribution | Distribution | Fee | Carried Interest | N/A
  perfTemplateMethod  String?                   // Granular | Gross Up | Both | N/A
  feeOffset           Boolean  @default(false)  // Does this transaction generate a fee offset?
  feeOffsetType       String?                   // Management Fee Base | Carry Basis | Both | None
  waterfallTier       String?                   // Return of Capital | Preferred Return | Catch-Up | Carried Interest | N/A
  commitmentImpact    String?                   // Reduces Unfunded | No Impact | Restores Unfunded | Increases Unfunded
  settlementDays      String?                   // T+0 | T+1 | T+2 | T+3 | T+5 | T+30
  autoReconcile       Boolean  @default(false)
  approvalRequired    Boolean  @default(false)
  taxReporting        String?                   // K-1 Line XX | Sched K-1 | None
  sortOrder           Int      @default(99)
  isActive            Boolean  @default(true)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  fundOverrides       FundTransactionOverride[]
}

model FundTransactionOverride {
  id                  String   @id @default(cuid())
  transParamCode      String
  transParam          TransactionParameter @relation(fields: [transParamCode], references: [code], onDelete: Cascade)
  fundId              String                        // Client fund / Entity identifier
  fundName            String?
  glDebit             String?
  glCredit            String?
  journalType         String?
  recallable          Boolean?
  feeOffset           Boolean?
  feeOffsetType       String?
  waterfallTier       String?
  settlementDays      String?
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([transParamCode, fundId])
}

// ──────────────────────────────────────────────
// WATERFALL ENGINE — Wf* prefixed models
// ──────────────────────────────────────────────

model WfFund {
  id               String   @id @default(cuid())
  name             String
  shortName        String
  strategy         String
  waterfallType    String
  status           String   @default("active")
  vintage          Int
  currency         String   @default("USD")
  totalCommitment  Float    @default(0)
  totalNav         Float    @default(0)
  totalDistributed Float    @default(0)
  totalUnrealized  Float    @default(0)
  exceptionCount   Int      @default(0)
  lastRefreshed    DateTime?
  validationStatus String   @default("pending")
  complexityScore  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  entityId       String?  @unique
  entity         Entity?  @relation(fields: [entityId], references: [id])

  terms          WfFundTerm?
  waterfallSteps WfWaterfallStep[]
  investors      WfFundInvestor[]
  navSnapshots   WfNavSnapshot[]
  exceptions     WfException[]
}

model WfFundTerm {
  id               String  @id @default(cuid())
  fundId           String  @unique
  hurdleRate       Float   @default(0.08)
  carryPct         Float   @default(0.20)
  catchupType      String  @default("full")
  mgmtFeeRate      Float   @default(0.02)
  mgmtFeeBasis     String  @default("committed")
  clawbackEnabled  Boolean @default(false)
  preferredReturn  Float   @default(0.08)
  fundLife         Int     @default(10)
  investmentPeriod Int     @default(5)
  fund             WfFund  @relation(fields: [fundId], references: [id])
}

model WfWaterfallStep {
  id          String @id @default(cuid())
  fundId      String
  stepOrder   Int
  stepName    String
  lpSplit     Float  @default(1.0)
  gpSplit     Float  @default(0.0)
  description String @default("")
  formula     String @default("")
  fund        WfFund @relation(fields: [fundId], references: [id])
  @@index([fundId])
}

model WfFundInvestor {
  id               String    @id @default(cuid())
  fundId           String
  investorName     String
  investorType     String    @default("institutional")
  investorClass    String    @default("A")
  commitment       Float     @default(0)
  contributed      Float     @default(0)
  distributed      Float     @default(0)
  nav              Float     @default(0)
  closingDate      DateTime
  overrideHurdle   Float?
  overrideCarryPct Float?
  overrideMgmtFee  Float?
  hasEqualization  Boolean   @default(false)
  equalizationAmt  Float     @default(0)
  fund             WfFund    @relation(fields: [fundId], references: [id])
  @@index([fundId])
}

model WfNavSnapshot {
  id           String   @id @default(cuid())
  fundId       String
  snapshotDate DateTime
  totalNav     Float
  unrealized   Float    @default(0)
  source       String   @default("canopy")
  fund         WfFund   @relation(fields: [fundId], references: [id])
}

model WfException {
  id               String    @id @default(cuid())
  fundId           String
  exceptionType    String
  severity         String    @default("medium")
  title            String
  description      String
  impactAmount     Float     @default(0)
  affectedEntities String    @default("[]")
  recommendedFix   String
  confidence       Float     @default(0.9)
  status           String    @default("open")
  resolvedAt       DateTime?
  resolvedBy       String?
  createdAt        DateTime  @default(now())
  fund             WfFund    @relation(fields: [fundId], references: [id])
  actions          WfRecommendedAction[]
}

model WfRecommendedAction {
  id          String      @id @default(cuid())
  exceptionId String
  actionType  String
  description String
  status      String      @default("pending")
  createdAt   DateTime    @default(now())
  completedAt DateTime?
  exception   WfException @relation(fields: [exceptionId], references: [id])
