model ExternalContact {
  id               String   @id @default(cuid())
  contactId        String   @unique
  name             String
  organization     String
  role             String
  contactType      String
  email            String?
  phone            String?
  city             String?
  country          String?
  linkedEntityIds  String?
  status           String   @default("Active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ──────────────────────────────────────────────
// DOCUMENTS
// ──────────────────────────────────────────────

model Document {
  id              String    @id @default(cuid())
  documentId      String    @unique
  name            String
  documentType    String
  entityName      String?
  clientName      String?
  status          String    @default("Draft")
  uploadedBy      String?
  uploadDate      DateTime
  fileSize        String?
  pageCount       Int?
  version         String    @default("1.0")
  confidentiality String    @default("Internal")
  expirationDate  DateTime?
  tags            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ──────────────────────────────────────────────
// PROJECTS & CALENDAR
// ──────────────────────────────────────────────

model Project {
  id              String    @id @default(cuid())
  projectId       String    @unique
  name            String
  description     String?
  projectType     String
  status          String    @default("Planning")
  priority        String    @default("Medium")
  clientName      String?
  leadName        String?
  startDate       DateTime
  targetEndDate   DateTime
  actualEndDate   DateTime?
  completionPct   Int       @default(0)
  totalTasks      Int       @default(0)
  completedTasks  Int       @default(0)
  budget          Decimal?
  spent           Decimal?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CalendarEvent {
  id            String   @id @default(cuid())
  eventId       String   @unique
  title         String
  description   String?
  eventType     String
  startTime     DateTime
  endTime       DateTime
  allDay        Boolean  @default(false)
  location      String?
  attendees     String?
  projectName   String?
  clientName    String?
  entityName    String?
  status        String   @default("Scheduled")
  priority      String   @default("Medium")
  recurrence    String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ──────────────────────────────────────────────
// COMMUNICATIONS / INTERACTIONS
// ──────────────────────────────────────────────

model Communication {
  id                String   @id @default(cuid())
  communicationId   String   @unique
  channel           String
  direction         String
  subject           String
  summary           String?
  fromName          String
  fromEmail         String?
  toName            String
  toEmail           String?
  ccNames           String?
  clientName        String?
  entityName        String?
  investorName      String?
  relatedProjectId  String?
  sentiment         String?
  urgency           String   @default("Normal")
  status            String   @default("Open")
  threadId          String?
  hasAttachments    Boolean  @default(false)
  attachmentCount   Int      @default(0)
  tags              String?
  communicationDate DateTime
  followUpDate      DateTime?
  resolvedDate      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ──────────────────────────────────────────────
// TREASURY CENTER
// ──────────────────────────────────────────────

model TreasuryAccount {
  id               String   @id @default(cuid())
  accountId        String   @unique
  accountName      String
  accountType      String
  institution      String
  currency         String   @default("USD")
  currentBalance   Decimal  @default(0)
  availableBalance Decimal  @default(0)
  pendingInflows   Decimal  @default(0)
  pendingOutflows  Decimal  @default(0)
  interestRate     Decimal?
  maturityDate     DateTime?
  entityName       String?
  clientName       String?
  status           String   @default("Active")
  lastActivityDate DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CashFlow {
  id              String   @id @default(cuid())
  cashFlowId      String   @unique
  flowType        String
  category        String
  amount          Decimal
  currency        String   @default("USD")
  accountName     String
  entityName      String?
  clientName      String?
  counterparty    String?
  description     String?
  transactionDate DateTime
  settlementDate  DateTime?
  status          String   @default("Settled")
  reference       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ──────────────────────────────────────────────
// TOOLBOX
// ──────────────────────────────────────────────

model Tool {
  id           String   @id @default(cuid())
  toolId       String   @unique
  name         String
  description  String
  category     String
  builtBy      String
  status       String   @default("Active")
  version      String   @default("1.0")
  language     String?
  runtime      String?
  endpoint     String?
  lastRunDate  DateTime?
  runCount     Int      @default(0)
  avgRunTimeMs Int?
  inputSchema  String?
  outputSchema String?
  documentation String?
  tags         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ──────────────────────────────────────────────
// RULE GRAPH & RELATIONSHIPS
// ──────────────────────────────────────────────

model Rule {
  id           String   @id @default(cuid())
  ruleId       String   @unique
  name         String
  description  String
  ruleType     String
  formula      String
  inputFields  String
  outputField  String
  dependsOn    String
  priority     Int
  status       String   @default("Active")
  category     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Relationship {
  id               String    @id @default(cuid())
  relationshipId   String    @unique
  sourceType       String
  sourceId         String
  sourceName       String
  targetType       String
  targetId         String
  targetName       String
  relationshipType String
  status           String    @default("Active")
  effectiveDate    DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ──────────────────────────────────────────────
// REPORTS — query-logic library, reusable, permissioned
// ──────────────────────────────────────────────

model Report {
  id              String      @id @default(cuid())
  reportId        String      @unique               // RPT-001 etc.
  name            String
  description     String?
  category        String                            // NAV, Tax, Compliance, Portfolio, …
  format          String      @default("PDF")       // PDF, Excel, Dashboard, XML, JSON
  frequency       String      @default("On-Demand") // Monthly, Quarterly, Annually, On-Demand, Weekly
  recipients      String?                           // free-text, comma-sep
  // Reusable query logic
  querySource     String      @default("prisma")    // prisma | sql | skill | composite
  queryLogic      String                            // JSON: { model, where, select, … } OR raw SQL OR skill name
  // Parameters the user can edit at run time. JSON schema-ish.
  parametersSchema String?                          // JSON-encoded array of { name, type, default, required, options? }
  // Permissioning
  ownerId         String                            // InternalUser.id
  ownerName       String?
  visibility      String      @default("Private")   // Private | Team | Org | Public
  sharedWithRoles String?                           // JSON array of role strings
  sharedWithUsers String?                           // JSON array of InternalUser ids
  requiredRole    String?                           // Min role to execute
  // Lifecycle
  status          String      @default("Active")    // Draft | Active | Archived | Deprecated
  version         String      @default("1.0.0")
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  runCount        Int         @default(0)
  tags            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  runs            ReportRun[]
}

model ReportRun {
  id            String   @id @default(cuid())
  runId         String   @unique
  reportId      String
  report        Report   @relation(fields: [reportId], references: [id])
  triggeredById String                     // InternalUser.id
  triggeredBy   String                     // display name
  parameters    String                     // JSON snapshot of params used
  status        String   @default("Queued") // Queued | Running | Success | Failed | Blocked
  rowCount      Int?
  durationMs    Int?
  outputRef     String?                    // path or URL to artifact
  error         String?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
}

// ──────────────────────────────────────────────
// TIME TRACKING — staff timesheets
// ──────────────────────────────────────────────

model Timesheet {
  id           String           @id @default(cuid())
  timesheetId  String           @unique
  userId       String                                // InternalUser.id
  userName     String
  weekStarting DateTime                              // Monday of the week (UTC midnight)
  status       String           @default("Draft")    // Draft | Submitted | Approved | Rejected
  totalHours   Decimal          @default(0)
  billableHours Decimal         @default(0)
  utilizationPct Decimal?
  submittedAt  DateTime?
  approvedAt   DateTime?
  approvedById String?
  approvedByName String?
  rejectedReason String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  entries      TimesheetEntry[]
}

model TimesheetEntry {
  id           String    @id @default(cuid())
  timesheetId  String
  timesheet    Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  date         DateTime                              // the day this entry covers
  clientName   String?                               // GP — optional
  entityName   String?                               // Fund — optional
  projectName  String?                               // Project — optional
  taskCode     String?                               // links to TaskDefinition.taskCode
  category     String                                // Billable | Non-Billable | Overhead | PTO | Sick | Holiday
  description  String
  hours        Decimal                               // 0.25 increments expected
  billable     Boolean   @default(true)
  billRate     Decimal?
  approved     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
